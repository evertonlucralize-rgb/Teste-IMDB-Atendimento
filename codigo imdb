<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Analista de Perfil — MBTI do Cliente</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap');

  :root{
    --paper:#FAF6EE;
    --ink:#1B2A4A;
    --ink-soft:#4A5670;
    --line:#DDD5C2;
    --amber:#C9763A;
    --amber-deep:#8E4E22;
    --amber-pale:#F3E2CE;
    --card:#FFFFFF;
  }

  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'Inter',sans-serif;
    min-height:100vh;
  }

  .wrap{max-width:880px;margin:0 auto;padding:48px 24px 80px;}

  header{
    border-bottom:1px solid var(--line);
    padding-bottom:28px;
    margin-bottom:36px;
  }
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    letter-spacing:.12em;
    text-transform:uppercase;
    color:var(--amber-deep);
    margin:0 0 10px;
  }
  h1{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:34px;
    margin:0 0 10px;
    line-height:1.15;
  }
  header p{
    color:var(--ink-soft);
    font-size:15px;
    max-width:560px;
    margin:0;
    line-height:1.6;
  }

  label{
    display:block;
    font-size:13px;
    font-weight:600;
    color:var(--ink-soft);
    margin-bottom:8px;
  }

  textarea{
    width:100%;
    min-height:220px;
    background:var(--card);
    border:1px solid var(--line);
    border-radius:6px;
    padding:16px;
    font-family:'Inter',sans-serif;
    font-size:14.5px;
    line-height:1.6;
    color:var(--ink);
    resize:vertical;
  }
  textarea:focus{outline:none;border-color:var(--amber);}
  textarea::placeholder{color:#A8A096;}

  .meta-row{
    display:flex;
    gap:16px;
    margin-top:16px;
    flex-wrap:wrap;
  }
  .meta-field{flex:1;min-width:160px;}
  input[type=text]{
    width:100%;
    background:var(--card);
    border:1px solid var(--line);
    border-radius:6px;
    padding:10px 12px;
    font-size:14px;
    color:var(--ink);
    font-family:'Inter',sans-serif;
  }
  input[type=text]:focus{outline:none;border-color:var(--amber);}

  .actions{
    margin-top:24px;
    display:flex;
    align-items:center;
    gap:14px;
  }
  button{
    font-family:'Inter',sans-serif;
    font-weight:600;
    font-size:14px;
    border:none;
    border-radius:6px;
    padding:13px 24px;
    cursor:pointer;
    background:var(--ink);
    color:var(--paper);
    transition:opacity .15s;
  }
  button:hover{opacity:.88;}
  button:disabled{opacity:.5;cursor:not-allowed;}
  .status{font-size:13px;color:var(--ink-soft);}

  .error{
    margin-top:18px;
    padding:12px 16px;
    border:1px solid #D8AFA0;
    background:#FBEDE7;
    color:#8C3B1F;
    border-radius:6px;
    font-size:13.5px;
  }

  #result{margin-top:48px;display:none;}

  .profile-head{
    display:flex;
    align-items:flex-end;
    gap:24px;
    border-bottom:1px solid var(--line);
    padding-bottom:24px;
    margin-bottom:28px;
  }
  .type-badge{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:54px;
    color:var(--amber-deep);
    letter-spacing:.01em;
    line-height:1;
  }
  .type-info{flex:1;}
  .type-name{
    font-family:'Fraunces',serif;
    font-size:21px;
    margin:0 0 6px;
  }
  .type-sub{
    font-size:13.5px;
    color:var(--ink-soft);
    margin:0;
  }
  .confidence{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    color:var(--ink-soft);
    text-align:right;
  }
  .confidence b{color:var(--ink);font-size:15px;}

  .dichotomies{
    display:grid;
    gap:14px;
    margin-bottom:36px;
  }
  .dich-row{
    display:grid;
    grid-template-columns:54px 1fr 54px;
    align-items:center;
    gap:12px;
  }
  .dich-label{
    font-family:'JetBrains Mono',monospace;
    font-size:13px;
    font-weight:500;
    color:var(--ink-soft);
  }
  .dich-label.right{text-align:right;}
  .dich-label.active{color:var(--ink);font-weight:600;}
  .bar-track{
    position:relative;
    height:6px;
    background:var(--amber-pale);
    border-radius:3px;
  }
  .bar-fill{
    position:absolute;
    top:0;bottom:0;
    background:var(--amber);
    border-radius:3px;
  }
  .bar-marker{
    position:absolute;
    top:50%;
    width:14px;height:14px;
    background:var(--ink);
    border-radius:50%;
    transform:translate(-50%,-50%);
    border:2px solid var(--paper);
  }

  .section-title{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    letter-spacing:.1em;
    text-transform:uppercase;
    color:var(--amber-deep);
    margin:0 0 14px;
  }

  .signals{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:8px;
    padding:18px 20px;
    margin-bottom:32px;
    font-size:14px;
    line-height:1.7;
    color:var(--ink-soft);
  }

  .tips{
    display:grid;
    gap:12px;
    margin-bottom:8px;
  }
  .tip{
    display:flex;
    gap:14px;
    background:var(--card);
    border:1px solid var(--line);
    border-left:3px solid var(--amber);
    border-radius:0 8px 8px 0;
    padding:14px 18px;
  }
  .tip-num{
    font-family:'Fraunces',serif;
    font-size:20px;
    color:var(--amber);
    min-width:22px;
  }
  .tip-text{font-size:14.5px;line-height:1.6;color:var(--ink);}

  .avoid{
    margin-top:28px;
    border-top:1px solid var(--line);
    padding-top:24px;
  }
  .avoid-list{margin:0;padding-left:20px;color:var(--ink-soft);font-size:14px;line-height:1.8;}

  footer{
    margin-top:56px;
    padding-top:20px;
    border-top:1px solid var(--line);
    font-size:12px;
    color:#A8A096;
  }

  .save-row{
    margin-top:24px;
    padding-top:24px;
    border-top:1px solid var(--line);
    display:flex;
    align-items:center;
    gap:14px;
  }
  .save-row button{
    background:var(--card);
    color:var(--ink);
    border:1px solid var(--line);
  }
  .save-row button:hover{border-color:var(--amber);opacity:1;}
  .save-confirm{
    font-size:13px;
    color:var(--amber-deep);
    display:none;
  }

  .history{
    margin-top:64px;
  }
  .history-head{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    margin-bottom:18px;
  }
  .history-count{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    color:var(--ink-soft);
  }
  .history-empty{
    font-size:14px;
    color:var(--ink-soft);
    border:1px dashed var(--line);
    border-radius:8px;
    padding:20px;
    text-align:center;
  }
  .history-list{
    display:grid;
    gap:10px;
  }
  .history-item{
    display:grid;
    grid-template-columns:48px 1fr auto auto;
    align-items:center;
    gap:14px;
    background:var(--card);
    border:1px solid var(--line);
    border-radius:8px;
    padding:12px 16px;
    cursor:pointer;
    transition:border-color .15s;
  }
  .history-item:hover{border-color:var(--amber);}
  .history-type{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:18px;
    color:var(--amber-deep);
  }
  .history-info{min-width:0;}
  .history-name{
    font-size:14px;
    font-weight:500;
    color:var(--ink);
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }
  .history-sub{
    font-size:12px;
    color:var(--ink-soft);
  }
  .history-date{
    font-family:'JetBrains Mono',monospace;
    font-size:11.5px;
    color:var(--ink-soft);
    white-space:nowrap;
  }
  .history-delete{
    background:none;
    border:none;
    color:var(--ink-soft);
    font-size:13px;
    padding:4px 8px;
    cursor:pointer;
  }
  .history-delete:hover{color:#8C3B1F;opacity:1;}

  @media (max-width:600px){
    .type-badge{font-size:40px;}
    .profile-head{flex-direction:column;align-items:flex-start;gap:10px;}
    .confidence{text-align:left;}
  }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <p class="eyebrow">Analista de perfil — atendimento ao cliente</p>
    <h1>Identifique o tipo MBTI do cliente</h1>
    <p>Cole a conversa abaixo. A ferramenta analisa o padrão de comunicação e devolve o tipo psicológico provável, junto com orientações práticas para conduzir o atendimento.</p>
  </header>

  <label for="conversation">Conversa com o cliente</label>
  <textarea id="conversation" placeholder="Cliente: Bom dia, preciso de uma solução rápida pra isso, já é a segunda vez que entro em contato...
Atendente: ...
Cliente: ..."></textarea>

  <div class="meta-row">
    <div class="meta-field">
      <label for="clientName">Nome ou identificador do cliente (opcional)</label>
      <input type="text" id="clientName" placeholder="Ex: João — pedido #4521">
    </div>
    <div class="meta-field">
      <label for="context">Contexto do atendimento (opcional)</label>
      <input type="text" id="context" placeholder="Ex: suporte técnico, pré-venda, reclamação">
    </div>
  </div>

  <div class="actions">
    <button id="analyzeBtn">Analisar perfil</button>
    <span class="status" id="statusText"></span>
  </div>

  <div id="errorBox" class="error" style="display:none;"></div>

  <div id="result"></div>

  <section class="history">
    <div class="history-head">
      <p class="section-title" style="margin:0;">Análises salvas</p>
      <span class="history-count" id="historyCount"></span>
    </div>
    <div id="historyList"></div>
  </section>

  <footer>As 16 dimensões seguem o modelo de personalidade MBTI (Myers-Briggs). O resultado é uma estimativa baseada em linguagem — use como apoio, não como diagnóstico definitivo.</footer>
</div>

<script>
const DICH = [
  {key:'EI', left:'E', right:'I', leftLabel:'Extrovertido', rightLabel:'Introvertido'},
  {key:'SN', left:'S', right:'N', leftLabel:'Sensorial', rightLabel:'Intuitivo'},
  {key:'TF', left:'T', right:'F', leftLabel:'Racional', rightLabel:'Sentimento'},
  {key:'JP', left:'J', right:'P', leftLabel:'Julgador', rightLabel:'Perceptivo'}
];

const TYPE_NAMES = {
  INTJ:'O arquiteto', INTP:'O lógico', ENTJ:'O comandante', ENTP:'O inovador',
  INFJ:'O advogado', INFP:'O mediador', ENFJ:'O protagonista', ENFP:'O ativista',
  ISTJ:'O logístico', ISFJ:'O defensor', ESTJ:'O executivo', ESFJ:'O cônsul',
  ISTP:'O virtuoso', ISFP:'O aventureiro', ESTP:'O empreendedor', ESFP:'O animador'
};

const btn = document.getElementById('analyzeBtn');
const statusText = document.getElementById('statusText');
const errorBox = document.getElementById('errorBox');
const resultBox = document.getElementById('result');

btn.addEventListener('click', analyze);

async function analyze(){
  const conversation = document.getElementById('conversation').value.trim();
  const clientName = document.getElementById('clientName').value.trim();
  const context = document.getElementById('context').value.trim();

  errorBox.style.display = 'none';
  resultBox.style.display = 'none';

  if(!conversation){
    errorBox.textContent = 'Cole o texto da conversa antes de analisar.';
    errorBox.style.display = 'block';
    return;
  }

  btn.disabled = true;
  statusText.textContent = 'Analisando padrão de comunicação...';

  const systemPrompt = `Você é um especialista em MBTI aplicado a análise de conversas de atendimento ao cliente. Analise APENAS o comportamento comunicativo do CLIENTE (ignore completamente o atendente).

## COMO AVALIAR CADA EIXO

### E vs I (Extroversão vs Introversão)
- **E (score baixo, 0–45):** mensagens longas espontâneas, conta detalhes da vida pessoal sem ser perguntado, usa linguagem animada/exclamativa, inicia assuntos secundários, parece confortável e fluido no chat.
- **I (score alto, 55–100):** respostas curtas e diretas, só responde o que foi perguntado, não compartilha contexto pessoal voluntariamente, linguagem contida, pausas longas implícitas.

### S vs N (Sensorial vs Intuitivo)
- **S (score baixo, 0–45):** foca em fatos concretos, datas, números, detalhes específicos ("o pedido número X feito no dia Y"); pede soluções práticas e imediatas; não especula sobre causas; descritivo.
- **N (score alto, 55–100):** fala em padrões e possibilidades ("sempre acontece isso", "deve ser porque..."); conecta o problema a cenários maiores; usa metáforas; menciona expectativas e interpretações.

### T vs F (Racional vs Sentimental)
- **T (score baixo, 0–45):** foca em eficiência e lógica; quer entender a causa do problema; linguagem impessoal; avalia a solução por critérios objetivos; não menciona impacto emocional.
- **F (score alto, 55–100):** menciona o impacto pessoal ("fiquei muito frustrado", "isso me prejudicou"); valoriza ser ouvido antes de ser solucionado; usa linguagem relacional; agradece e se preocupa com o relacionamento.

### J vs P (Julgador vs Perceptivo)
- **J (score baixo, 0–45):** quer prazo definido, plano claro e fechamento rápido; incomoda-se com ambiguidade; estruturado nas perguntas; pressiona por confirmação e comprometimento.
- **P (score alto, 55–100):** aceita soluções parciais; muda de assunto no meio; traz novas questões enquanto o problema anterior não foi resolvido; flexível e adaptável; não pressiona por prazo.

## REGRAS IMPORTANTES
1. Avalie cada eixo de forma INDEPENDENTE com base nos sinais acima — não deixe um eixo influenciar outro.
2. NÃO há um tipo "padrão". Os 16 tipos são igualmente prováveis. EVITE viés para INTJ, ENTJ ou qualquer outro tipo específico.
3. Scores entre 40–60 indicam ambiguidade genuína — use-os quando os sinais forem mistos.
4. O campo "type" DEVE ser consistente com os scores: EI<50→E, EI≥50→I; SN<50→S, SN≥50→N; TF<50→T, TF≥50→F; JP<50→J, JP≥50→P.
5. Se a conversa for curta, ainda infira com base nos sinais disponíveis, mas reduza o "confidence" para no máximo 45.

## FORMATO DE RESPOSTA
Responda APENAS com JSON válido, sem markdown, sem texto antes ou depois:
{
  "type": "XXXX",
  "confidence": 0-100,
  "scores": {"EI": 0-100, "SN": 0-100, "TF": 0-100, "JP": 0-100},
  "signals": "2-3 frases citando comportamentos ESPECÍFICOS da conversa que indicaram cada dimensão",
  "tips": ["dica prática e específica para este tipo 1", "dica 2", "dica 3", "dica 4"],
  "avoid": ["comportamento concreto a evitar 1", "o que evitar 2", "o que evitar 3"]
}`;

  const userPrompt = `${context ? 'Contexto do atendimento: ' + context + '\\n\\n' : ''}${clientName ? 'Cliente: ' + clientName + '\\n\\n' : ''}Conversa:\\n${conversation}`;

  try{
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: 'user', content: userPrompt }]
      })
    });

    if(!response.ok){
      throw new Error('Falha na chamada da API (status ' + response.status + ')');
    }

    const data = await response.json();
    const textBlock = data.content.find(b => b.type === 'text');
    if(!textBlock) throw new Error('Resposta sem conteúdo de texto.');

    const cleaned = textBlock.text.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(cleaned);

    renderResult(parsed, clientName);
    statusText.textContent = 'Análise concluída.';
  }catch(err){
    console.error(err);
    errorBox.textContent = 'Não foi possível concluir a análise: ' + err.message;
    errorBox.style.display = 'block';
    statusText.textContent = '';
  }finally{
    btn.disabled = false;
  }
}

function renderResult(data, clientName){
  const type = (data.type || '????').toUpperCase();
  const typeName = TYPE_NAMES[type] || 'Tipo não identificado';
  const confidence = Math.round(data.confidence ?? 0);

  let dichHtml = '';
  DICH.forEach(d => {
    const score = Math.max(0, Math.min(100, Math.round(data.scores?.[d.key] ?? 50)));
    const leftActive = score < 50;
    dichHtml += `
      <div class="dich-row">
        <span class="dich-label ${leftActive ? 'active' : ''}">${d.left} · ${d.leftLabel}</span>
        <div class="bar-track">
          <div class="bar-fill" style="left:0;width:${score}%;"></div>
          <div class="bar-marker" style="left:${score}%;"></div>
        </div>
        <span class="dich-label right ${!leftActive ? 'active' : ''}">${d.rightLabel} · ${d.right}</span>
      </div>`;
  });

  let tipsHtml = '';
  (data.tips || []).forEach((tip, i) => {
    tipsHtml += `<div class="tip"><span class="tip-num">${String(i+1).padStart(2,'0')}</span><span class="tip-text">${escapeHtml(tip)}</span></div>`;
  });

  let avoidHtml = '';
  (data.avoid || []).forEach(a => {
    avoidHtml += `<li>${escapeHtml(a)}</li>`;
  });

  resultBox.innerHTML = `
    <div class="profile-head">
      <span class="type-badge">${escapeHtml(type)}</span>
      <div class="type-info">
        <p class="type-name">${escapeHtml(typeName)}${clientName ? ' — ' + escapeHtml(clientName) : ''}</p>
        <p class="type-sub">Perfil estimado a partir do padrão de comunicação na conversa</p>
      </div>
      <div class="confidence">confiança<br><b>${confidence}%</b></div>
    </div>

    <p class="section-title">Eixos de personalidade</p>
    <div class="dichotomies">${dichHtml}</div>

    <p class="section-title">O que indicou esse perfil</p>
    <div class="signals">${escapeHtml(data.signals || '')}</div>

    <p class="section-title">Como atender esse cliente</p>
    <div class="tips">${tipsHtml}</div>

    <div class="avoid">
      <p class="section-title">Evite</p>
      <ul class="avoid-list">${avoidHtml}</ul>
    </div>

    <div class="save-row">
      <button id="saveBtn">Inserir nova análise</button>
      <span class="save-confirm" id="saveConfirm">Análise salva no histórico.</span>
    </div>
  `;
  resultBox.style.display = 'block';

  currentAnalysis = { ...data, clientName, savedAt: Date.now() };
  document.getElementById('saveBtn').addEventListener('click', saveCurrentAnalysis);
}

let currentAnalysis = null;

function saveCurrentAnalysis(){
  if(!currentAnalysis) return;
  const history = loadHistory();
  history.unshift(currentAnalysis);
  localStorage.setItem('mbti_history', JSON.stringify(history));
  renderHistory();
  const confirm = document.getElementById('saveConfirm');
  confirm.style.display = 'inline';
  setTimeout(() => { confirm.style.display = 'none'; }, 2500);
}

function loadHistory(){
  try{
    return JSON.parse(localStorage.getItem('mbti_history') || '[]');
  }catch(e){
    return [];
  }
}

function deleteHistoryItem(index){
  const history = loadHistory();
  history.splice(index, 1);
  localStorage.setItem('mbti_history', JSON.stringify(history));
  renderHistory();
}

function renderHistory(){
  const history = loadHistory();
  const listEl = document.getElementById('historyList');
  const countEl = document.getElementById('historyCount');
  countEl.textContent = history.length ? history.length + (history.length === 1 ? ' registro' : ' registros') : '';

  if(!history.length){
    listEl.innerHTML = '<div class="history-empty">Nenhuma análise salva ainda. Analise uma conversa e clique em "Inserir nova análise" para guardá-la aqui.</div>';
    return;
  }

  listEl.innerHTML = '<div class="history-list">' + history.map((item, i) => {
    const date = new Date(item.savedAt);
    const dateStr = date.toLocaleDateString('pt-BR') + ' ' + date.toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'});
    const type = (item.type || '????').toUpperCase();
    return `
      <div class="history-item" data-index="${i}">
        <span class="history-type">${escapeHtml(type)}</span>
        <div class="history-info">
          <p class="history-name">${escapeHtml(item.clientName || 'Cliente sem nome')}</p>
          <p class="history-sub">${escapeHtml(TYPE_NAMES[type] || '')} · confiança ${Math.round(item.confidence ?? 0)}%</p>
        </div>
        <span class="history-date">${dateStr}</span>
        <button class="history-delete" data-index="${i}" title="Excluir">remover</button>
      </div>`;
  }).join('') + '</div>';

  listEl.querySelectorAll('.history-item').forEach(el => {
    el.addEventListener('click', (e) => {
      if(e.target.classList.contains('history-delete')) return;
      const item = history[parseInt(el.dataset.index)];
      renderResult(item, item.clientName);
      window.scrollTo({ top: resultBox.offsetTop - 20, behavior: 'smooth' });
    });
  });

  listEl.querySelectorAll('.history-delete').forEach(el => {
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      deleteHistoryItem(parseInt(el.dataset.index));
    });
  });
}

renderHistory();

function escapeHtml(str){
  const div = document.createElement('div');
  div.textContent = str ?? '';
  return div.innerHTML;
}
</script>
</body>
</html>
